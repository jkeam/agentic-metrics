FROM registry.access.redhat.com/ubi9/python-312-minimal:9.7 as build
USER 0
COPY pyproject.toml uv.lock .
RUN pip install -U pip && \
    pip install uv && \
    uv sync && \
    uv pip freeze > requirements.txt

# Final uses requirements.txt
FROM registry.access.redhat.com/ubi9/python-312-minimal:9.7 as final

# install deps
USER 1001
COPY --from=build /opt/app-root/src/requirements.txt .
RUN pip install -U pip && pip install -r requirements.txt

# source code
COPY . .

# Allow statements and log messages to immediately appear
ENV PYTHONUNBUFFERED True

EXPOSE 8000
CMD ["gunicorn", "-w", "4", "-b", "0.0.0.0", "dashboard:create_app()"]
